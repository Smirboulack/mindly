{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "mindly",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "mindly-base",
			"database_id": "ff4192ae-b26c-40ba-981b-9dc6c578d936",
		}
	]
}